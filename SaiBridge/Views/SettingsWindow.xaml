<Window
    x:Class="SaiBridge.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="设置"
    Width="500"
    Height="420"
    ResizeMode="NoResize"
    Background="{DynamicResource WindowBackground}">

    <ScrollViewer
        Background="{DynamicResource WindowBackground}">

        <StackPanel
            Margin="25"
            Background="{DynamicResource WindowBackground}">

            <TextBlock
                FontSize="24"
                FontWeight="Bold"
                Foreground="{DynamicResource Foreground}"
                Text="设置"/>

            <Separator Margin="0,15"/>

            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource Foreground}"
                Text="外观"/>

            <CheckBox
                x:Name="DarkMode"
                Margin="0,15,0,0"
                Foreground="{DynamicResource Foreground}"
                Content="深色模式"/>

            <CheckBox
                x:Name="GlassEffect"
                Margin="0,10,0,0"
                Foreground="{DynamicResource Foreground}"
                Content="液态玻璃 (Windows 11)"/>

            <Separator Margin="0,20"/>

            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource Foreground}"
                Text="系统"/>

            <CheckBox
                x:Name="AutoStart"
                Margin="0,15,0,0"
                Foreground="{DynamicResource Foreground}"
                Content="开机自动启动"/>

            <CheckBox
                x:Name="AutoUpdate"
                Margin="0,10,0,0"
                Foreground="{DynamicResource Foreground}"
                Content="自动检查更新"/>

            <Separator Margin="0,20"/>

            <Button
                Width="120"
                Height="40"
                HorizontalAlignment="Right"
                Background="{DynamicResource ButtonBackground}"
                Foreground="{DynamicResource Foreground}"
                BorderBrush="{DynamicResource BorderBrush}"
                Click="Save_Click"
                Content="保存"/>

        </StackPanel>

    </ScrollViewer>

</Window>