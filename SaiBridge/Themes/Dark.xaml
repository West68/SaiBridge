<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neutral Dark Glass -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FF111111"/>

    <SolidColorBrush x:Key="PanelBackground" Color="#DD232323"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#55FFFFFF"/>

    <SolidColorBrush x:Key="Foreground" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="SecondaryForeground" Color="#FFD0D0D0"/>

    <SolidColorBrush x:Key="TextBoxBackground" Color="#E62B2B2B"/>

    <SolidColorBrush x:Key="ButtonBackground" Color="#DD383838"/>

    <SolidColorBrush x:Key="ButtonHover" Color="#DD3B3B3B"/>

    <SolidColorBrush x:Key="GlassInnerEdge" Color="#33FFFFFF"/>

    <SolidColorBrush x:Key="FocusRing" Color="#FFFFFFFF"/>
    <DropShadowEffect x:Key="GlassShadowEffect"
    BlurRadius="18"
    ShadowDepth="4" Direction="270" Color="#00050D" Opacity="0.58"/>
    <DropShadowEffect x:Key="FloatingShadowEffect"
    BlurRadius="12"
    ShadowDepth="3" Direction="270" Color="#00040C" Opacity="0.58"/>

    <Style TargetType="Window"><Setter Property="Background" Value="{DynamicResource WindowBackground}"/><Setter Property="Foreground" Value="{DynamicResource Foreground}"/><Setter Property="FontFamily" Value="Segoe UI Variable"/></Style>
    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Foreground}"/></Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        <Setter Property="BorderBrush"
        Value="#55FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="GroupBox"><Grid SnapsToDevicePixels="True">
            <Border x:Name="Card" Margin="0,9,0,0" CornerRadius="18" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Effect="{StaticResource GlassShadowEffect}"/>
            <Border Margin="1,10,1,1" CornerRadius="17" BorderBrush="{DynamicResource GlassInnerEdge}" BorderThickness="1" Opacity="0.55"/>
                        <Border Margin="2,11,2,2" CornerRadius="16" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#35FFFFFF" Offset="0"/>
                                    <GradientStop Color="#10FFFFFF" Offset="0.28"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.68"/></LinearGradientBrush></Border.Background></Border>
                        <Border Margin="12,0,0,0" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#55242424" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="9"><ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/></Border>
            <ContentPresenter Margin="0,9,0,0" ContentSource="Content"/>
        </Grid></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
        <Setter Property="BorderBrush" Value="#55FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="SelectionBrush" Value="#6699CCFF"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Grid>
            <Border x:Name="InputGlass" CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Effect="{StaticResource FloatingShadowEffect}"/>
                        <Border Margin="1" CornerRadius="11" BorderBrush="#22FFFFFF" BorderThickness="1" Opacity="0.48"/>
                        <Border Margin="2" CornerRadius="10" VerticalAlignment="Top" Height="13" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/></LinearGradientBrush></Border.Background></Border>
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Stretch"/>
        </Grid><ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="InputGlass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/><Setter TargetName="InputGlass" Property="BorderThickness" Value="2"/></Trigger>
            <Trigger Property="IsReadOnly" Value="True"><Setter TargetName="InputGlass" Property="Background" Value="#59131F35"/></Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="InputGlass" Property="Opacity" Value="0.5"/></Trigger>
        </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style x:Key="LogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="8"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Background="Transparent" HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}" VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
        <Setter Property="BorderBrush" Value="#55FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="14,8"/><Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform><ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/></Grid.RenderTransform>
            <Border x:Name="Shadow" CornerRadius="15" Background="#35101B30" Effect="{StaticResource FloatingShadowEffect}"/>
            <Border x:Name="Glass" CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        <Border CornerRadius="14" Margin="1" BorderBrush="#22FFFFFF" BorderThickness="1"/>
                        <Border x:Name="Specular" Height="18" Margin="3,2,3,0" VerticalAlignment="Top" CornerRadius="12" Opacity="0.45">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#40FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/></LinearGradientBrush></Border.Background></Border>
                        <Border x:Name="HoverSheen" CornerRadius="14" Margin="1" BorderBrush="#55FFFFFF" BorderThickness="1" Opacity="0"/>
            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
        </Grid><ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Glass" Property="Background" Value="{DynamicResource ButtonHover}"/><Setter TargetName="Shadow" Property="Opacity" Value="0.78"/></Trigger>
            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Glass" Property="Opacity" Value="0.78"/><Setter TargetName="Specular" Property="Opacity" Value="0.33"/></Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Glass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/><Setter TargetName="Glass" Property="BorderThickness" Value="2"/></Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Glass" Property="Opacity" Value="0.42"/><Setter TargetName="Shadow" Property="Opacity" Value="0"/></Trigger>
            <EventTrigger RoutedEvent="MouseEnter"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverSheen" Storyboard.TargetProperty="Opacity" To="0.86" Duration="0:0:0.18"/></Storyboard></BeginStoryboard></EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverSheen" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/></Storyboard></BeginStoryboard></EventTrigger>
        </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#33202020"/><Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/><Setter Property="Padding" Value="0"/></Style>
    <Style TargetType="StatusBarItem"><Setter Property="Padding" Value="0"/></Style>
    <Style TargetType="ScrollBar"><Setter Property="Width" Value="11"/><Setter Property="Background" Value="Transparent"/></Style>
    <Style TargetType="ScrollViewer"><Setter Property="Background" Value="Transparent"/></Style>
</ResourceDictionary>
