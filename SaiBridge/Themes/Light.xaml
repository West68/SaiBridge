<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════
         SaiBridge Light — Floating Translucent Glass
         High transparency, visible backdrop, light glass feel.
         ═══════════════════════════════════════════════ -->

    <!-- ── Palette ──────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFECEEF3"/>
    <SolidColorBrush x:Key="PanelBackground"  Color="#CCF8FAFD"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="#40C4CAD2"/>
    <SolidColorBrush x:Key="Foreground"       Color="#FF161A20"/>
    <SolidColorBrush x:Key="SecondaryForeground" Color="#FF525A64"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#D4F4F6FA"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#CCF8FAFD"/>
    <SolidColorBrush x:Key="ButtonHover"      Color="#E8FFFFFF"/>
    <SolidColorBrush x:Key="ButtonPressed"    Color="#A8E6EAF0"/>
    <SolidColorBrush x:Key="GlassInnerEdge"   Color="#58FFFFFF"/>
    <SolidColorBrush x:Key="FocusRing"        Color="#FF4A8CF7"/>
    <SolidColorBrush x:Key="CardHeaderBg"     Color="#98F4F6FA"/>

    <!-- ── Elevation ────────────────────────────── -->
    <DropShadowEffect x:Key="CardShadow"
        BlurRadius="24" ShadowDepth="6" Direction="270"
        Color="#18384858" Opacity="0.24"/>
    <DropShadowEffect x:Key="InputShadow"
        BlurRadius="8" ShadowDepth="1" Direction="270"
        Color="#12243444" Opacity="0.18"/>
    <DropShadowEffect x:Key="ButtonShadow"
        BlurRadius="10" ShadowDepth="3" Direction="270"
        Color="#14283848" Opacity="0.20"/>

    <!-- ── Global ───────────────────────────────── -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         GroupBox → Translucent Glass Card
         ═══════════════════════════════════════════════ -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground"    Value="{DynamicResource Foreground}"/>
        <Setter Property="Background"    Value="{DynamicResource PanelBackground}"/>
        <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid SnapsToDevicePixels="True">
                        <!-- shadow -->
                        <Border Margin="0,9,0,0" CornerRadius="18"
                                Background="Transparent"
                                Effect="{StaticResource CardShadow}"/>
                        <!-- body -->
                        <Border x:Name="Card" Margin="0,9,0,0" CornerRadius="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                        <!-- inner edge highlight -->
                        <Border Margin="1,10,1,1" CornerRadius="17"
                                BorderBrush="{DynamicResource GlassInnerEdge}"
                                BorderThickness="1" Opacity="0.48"/>
                        <!-- top specular wash -->
                        <Border Margin="2,11,2,2" CornerRadius="16" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#50FFFFFF" Offset="0.00"/>
                                    <GradientStop Color="#18FFFFFF" Offset="0.15"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.38"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- header chip -->
                        <Border Margin="12,0,0,0" Padding="7,3"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Background="{DynamicResource CardHeaderBg}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ContentPresenter Margin="0,9,0,0" ContentSource="Content"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════
         TextBox → Translucent Input
         ═══════════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground"     Value="{DynamicResource Foreground}"/>
        <Setter Property="Background"     Value="{DynamicResource TextBoxBackground}"/>
        <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush"     Value="#FF2B3B54"/>
        <Setter Property="SelectionBrush" Value="#604A8CF7"/>
        <Setter Property="Padding"        Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border CornerRadius="10" Background="Transparent"
                                Effect="{StaticResource InputShadow}"/>
                        <Border x:Name="InputGlass" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                        <Border Margin="1" CornerRadius="9"
                                BorderBrush="{DynamicResource GlassInnerEdge}"
                                BorderThickness="1" Opacity="0.40"/>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Stretch"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="InputGlass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                            <Setter TargetName="InputGlass" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="InputGlass" Property="Background" Value="#60F0F2F6"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputGlass" Property="Opacity" Value="0.40"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  Background="Transparent"
                                  HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════
         Button → Translucent Glass Pill
         ═══════════════════════════════════════════════ -->
    <Style TargetType="Button">
        <Setter Property="Foreground"     Value="{DynamicResource Foreground}"/>
        <Setter Property="Background"     Value="{DynamicResource ButtonBackground}"/>
        <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"        Value="14,8"/>
        <Setter Property="Cursor"         Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- shadow -->
                        <Border x:Name="Shadow" CornerRadius="14"
                                Background="Transparent"
                                Effect="{StaticResource ButtonShadow}"/>
                        <!-- body -->
                        <Border x:Name="Glass" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                        <!-- inner edge -->
                        <Border CornerRadius="13" Margin="1"
                                BorderBrush="{DynamicResource GlassInnerEdge}"
                                BorderThickness="1" Opacity="0.58"/>
                        <!-- specular top -->
                        <Border x:Name="Specular" Height="14" Margin="3,2,3,0"
                                VerticalAlignment="Top" CornerRadius="11" Opacity="0.48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#60FFFFFF" Offset="0"/>
                                    <GradientStop Color="#08FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- hover ring -->
                        <Border x:Name="HoverSheen" CornerRadius="13" Margin="1"
                                BorderBrush="{DynamicResource FocusRing}"
                                BorderThickness="1.2" Opacity="0"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Glass"    Property="Background" Value="{DynamicResource ButtonHover}"/>
                            <Setter TargetName="Shadow"   Property="Opacity"   Value="0.90"/>
                            <Setter TargetName="Specular" Property="Opacity"   Value="0.58"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Glass"    Property="Background" Value="{DynamicResource ButtonPressed}"/>
                            <Setter TargetName="Shadow"   Property="Opacity"   Value="0.38"/>
                            <Setter TargetName="Specular" Property="Opacity"   Value="0.22"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Glass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                            <Setter TargetName="Glass" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Glass"  Property="Opacity" Value="0.35"/>
                            <Setter TargetName="Shadow" Property="Opacity" Value="0"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverSheen"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.68" Duration="0:0:0.18"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverSheen"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.24"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#14B8C0C8"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
        <Setter Property="Padding"    Value="0"/>
    </Style>
    <Style TargetType="StatusBarItem">
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="11"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
</ResourceDictionary>
