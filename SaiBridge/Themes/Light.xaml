<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Tahoe-inspired light liquid glass palette.  Semi-transparent layers keep the existing backdrop visible. -->
    <Color x:Key="GlassTint">#48EAF2FF</Color>
    <SolidColorBrush x:Key="WindowBackground" Color="#FFF8F8F8"/>
    <SolidColorBrush x:Key="PanelBackground"  Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#88FFFFFF"/>
    <SolidColorBrush x:Key="Foreground" Color="#FF202020"/>
    <SolidColorBrush x:Key="SecondaryForeground" Color="#FF666666"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#CCFFFFFF"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="ButtonHover" Color="#E8FFFFFF"/>
    <SolidColorBrush x:Key="GlassInnerEdge" Color="#46FFFFFF"/>
    <SolidColorBrush x:Key="GlassShadow" Color="#26152A48"/>
    <SolidColorBrush x:Key="FocusRing" Color="#FF4EA3FF"/>

    <DropShadowEffect x:Key="GlassShadowEffect" BlurRadius="18" ShadowDepth="5" Direction="270" Color="#435A7590" Opacity="0.20"/>
    <DropShadowEffect x:Key="FloatingShadowEffect" BlurRadius="10" ShadowDepth="3" Direction="270" Color="#384C6680" Opacity="0.22"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Card" Margin="0,9,0,0" CornerRadius="18" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Effect="{StaticResource GlassShadowEffect}"/>
                        <Border Margin="1,10,1,1" CornerRadius="17" BorderBrush="{DynamicResource GlassInnerEdge}" BorderThickness="1" Opacity="0.55"/>
                        <Border Margin="2,11,2,2" CornerRadius="16" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#88FFFFFF" Offset="0"/>
                                    <GradientStop Color="#30FFFFFF" Offset="0.22"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.55"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="HeaderSurface" Margin="12,0,0,0" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#AAFFFFFF" BorderBrush="#AAFFFFFF" BorderThickness="1" CornerRadius="9">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ContentPresenter Margin="0,9,0,0" ContentSource="Content"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
        <Setter Property="BorderBrush" Value="#88FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="#24364E"/>
        <Setter Property="SelectionBrush" Value="#805B9DFF"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="InputGlass" CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Effect="{StaticResource FloatingShadowEffect}"/>
                        <Border Margin="1" CornerRadius="11" BorderBrush="#48FFFFFF" BorderThickness="1" Opacity="0.48"/>
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Stretch"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="InputGlass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/><Setter TargetName="InputGlass" Property="BorderThickness" Value="2"/></Trigger>
                        <Trigger Property="IsReadOnly" Value="True"><Setter TargetName="InputGlass" Property="Background" Value="#56FFFFFF"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="InputGlass" Property="Opacity" Value="0.5"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Background="Transparent" HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}" VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
        <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
        <Setter Property="BorderBrush" Value="#88FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform><ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/></Grid.RenderTransform>
                        <Border x:Name="Shadow" CornerRadius="15" Background="#1B183859" Effect="{StaticResource FloatingShadowEffect}"/>
                        <Border x:Name="Glass" CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        <Border CornerRadius="14" Margin="1" BorderBrush="#80FFFFFF" BorderThickness="1" Opacity="0.58"/>
                        <Border x:Name="Specular" Height="18" Margin="3,2,3,0" VerticalAlignment="Top" CornerRadius="12" Opacity="0.55">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#80FFFFFF" Offset="0"/>
                                    <GradientStop Color="#15FFFFFF" Offset="1"/></LinearGradientBrush></Border.Background>
                        </Border>
                        <Border x:Name="HoverSheen" CornerRadius="14" Margin="1" BorderBrush="#AAFFFFFF" BorderThickness="1" Opacity="0"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Glass" Property="Background" Value="{DynamicResource ButtonHover}"/><Setter TargetName="Shadow" Property="Opacity" Value="0.72"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Glass" Property="Opacity" Value="0.83"/><Setter TargetName="Specular" Property="Opacity" Value="0.35"/></Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Glass" Property="BorderBrush" Value="{DynamicResource FocusRing}"/><Setter TargetName="Glass" Property="BorderThickness" Value="2"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Glass" Property="Opacity" Value="0.45"/><Setter TargetName="Shadow" Property="Opacity" Value="0"/></Trigger>
                        <EventTrigger RoutedEvent="MouseEnter"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverSheen" Storyboard.TargetProperty="Opacity" To="0.82" Duration="0:0:0.18"/></Storyboard></BeginStoryboard></EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave"><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="HoverSheen" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/></Storyboard></BeginStoryboard></EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="StatusBar"><Setter Property="Background" Value="#22FFFFFF"/><Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/><Setter Property="Padding" Value="0"/></Style>
    <Style TargetType="StatusBarItem"><Setter Property="Padding" Value="0"/></Style>
    <Style TargetType="ScrollBar"><Setter Property="Width" Value="11"/><Setter Property="Background" Value="Transparent"/></Style>
    <Style TargetType="ScrollViewer"><Setter Property="Background" Value="Transparent"/></Style>
</ResourceDictionary>
