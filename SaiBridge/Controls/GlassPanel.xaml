<UserControl x:Class="SaiBridge.Controls.GlassPanel"
             
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Border
        CornerRadius="22"
        Background="#55FFFFFF"
        BorderBrush="#66FFFFFF"
        BorderThickness="1">


        <Border.Effect>

            <DropShadowEffect
                BlurRadius="20"
                ShadowDepth="0"
                Opacity="0.35"/>

        </Border.Effect>


        <Grid>

            <!-- 玻璃高光层 -->

            <Border
                CornerRadius="22"
                Opacity="0.35">


                <Border.Background>

                    <LinearGradientBrush
                        StartPoint="0,0"
                        EndPoint="0,1">

                        <GradientStop
                            Color="#80FFFFFF"
                            Offset="0"/>

                        <GradientStop
                            Color="#00FFFFFF"
                            Offset="0.35"/>

                    </LinearGradientBrush>


                </Border.Background>


            </Border>


            <!-- 内容 -->

            <ContentPresenter
                Margin="0"/>


        </Grid>


    </Border>


</UserControl>